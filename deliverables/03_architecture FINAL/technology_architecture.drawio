          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AUDIT → PG Audit -->
        <mxCell id="e27" value="JDBC 5432 TLS" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="cs_audit" target="db_pg_audit">
          <mxGeometry relative="1" as="geometry"/>
