        <!-- CMS → PG CMS -->
        <mxCell id="e28" value="JDBC 5432 TLS" style="endArrow=classic;html=1;exitX=0.4;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="cs_cms" target="db_pg_cms">
