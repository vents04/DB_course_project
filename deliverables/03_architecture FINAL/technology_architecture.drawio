        <!-- External regulators (escalation) from BBO_BE -->
        <mxCell id="e37" value="HTTPS 443 (при ескалация)" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;dashed=1" edge="1" parent="1" source="ch_bbo_be" target="ext_bnb">
