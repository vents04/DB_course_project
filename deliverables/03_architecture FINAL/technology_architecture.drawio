        </mxCell>

        <!-- CMS → MinIO -->
        <mxCell id="e29" value="S3 HTTPS 9000" style="endArrow=classic;html=1;exitX=0.7;exitY=1;entryX=0.2;entryY=0;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="cs_cms" target="db_minio">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CORE_BANKING → Oracle -->
        <mxCell id="e30" value="JDBC 1521 TLS" style="endArrow=classic;html=1;exitX=0.2;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="core_bank" target="db_oracle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CARD_SYSTEM → SQL Server -->
        <mxCell id="e31" value="TDS 1433 TLS" style="endArrow=classic;html=1;exitX=0.8;exitY=1;entryX=0.3;entryY=0;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="card_sys" target="db_mssql">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1780" y="1440"/></Array>
