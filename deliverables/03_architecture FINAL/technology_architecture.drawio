          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Session → Redis -->
        <mxCell id="e33" value="Redis 6379 TLS" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="ch_session" target="db_redis">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="890" y="1240"/><mxPoint x="1000" y="1440"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- Analytics → Elasticsearch -->
        <mxCell id="e34" value="HTTPS 9200" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="cs_analytics" target="db_es">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- BBO_BE → Session -->
        <mxCell id="e35" value="REST 8443" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="ch_bbo_be" target="ch_session">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="740" y="765"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- API Gateway → Identity Provider -->
        <mxCell id="e36" value="OIDC 443" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff" edge="1" parent="1" source="dmz_api" target="dmz_idp">
