<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_ComplaintProcess"
                  targetNamespace="http://unicreditbulbank.bg/bpmn/complaint"
                  exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Bank" name="УниКредит Булбанк" processRef="Process_Bank"/>
    <bpmn:participant id="Participant_Client" name="Клиент" processRef="Process_Client"/>
    <bpmn:messageFlow id="MF_OpenComplaint" name="Отваря Помощ &gt; Жалби" sourceRef="Task_Client_Open" targetRef="Task_Bot_Collect"/>
    <bpmn:messageFlow id="MF_ClientInfo" name="Допълнителна информация" sourceRef="Task_Client_ProvideInfo" targetRef="Task_Spec_Investigate"/>
    <bpmn:messageFlow id="MF_ClientResp" name="Отговор на клиента" sourceRef="Task_Client_Review" targetRef="Gateway_ClientResp"/>
    <bpmn:messageFlow id="MF_Ack" name="Потвърждение (in-app + email + push)" sourceRef="SendTask_Ack" targetRef="Task_Client_Review"/>
    <bpmn:messageFlow id="MF_ReqInfo" name="Запитване за инфо (in-app + email + push)" sourceRef="SendTask_RequestInfo" targetRef="Task_Client_ProvideInfo"/>
    <bpmn:messageFlow id="MF_Response" name="Отговор (in-app + email + push)" sourceRef="SendTask_Response" targetRef="Task_Client_Review"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Bank" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Bank">
      <bpmn:lane id="Lane_Chatbot" name="AI Чатбот">
        <bpmn:flowNodeRef>Task_Bot_Collect</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NLP</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Tier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TierA_Info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TierB_Action</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LogCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WantFormal</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_CMS" name="Система за жалби (CMS)">
        <bpmn:flowNodeRef>Task_Register</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_Ack</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Route</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MonetaryAction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExecuteApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendTask_RequestInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Survey</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Survey</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Specialist" name="Обработващ специалист + AI Ко-пилот">
        <bpmn:flowNodeRef>Task_CoPilot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Spec_Investigate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_NeedInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Spec_Decide</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Ръководител">
        <bpmn:flowNodeRef>Task_Mgr_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MgrOutcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_External</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:task id="Task_Bot_Collect" name="Събира категория, описание, прикачени файлове">
      <bpmn:incoming>Flow_Start_Bot</bpmn:incoming>
      <bpmn:outgoing>Flow_Bot_NLP</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_NLP" name="NLP анализ + определяне на Tier (A/B/C/D)">
      <bpmn:incoming>Flow_Bot_NLP</bpmn:incoming>
      <bpmn:outgoing>Flow_NLP_Tier</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Tier" name="Tier?">
      <bpmn:incoming>Flow_NLP_Tier</bpmn:incoming>
      <bpmn:outgoing>Flow_Tier_A</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tier_B</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tier_CD</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_TierA_Info" name="Tier A: Предоставя информация (без банково действие)">
      <bpmn:incoming>Flow_Tier_A</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Log</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_TierB_Action" name="Tier B: Изпълнява клиентско действие (напр. блок. карта)">
      <bpmn:incoming>Flow_Tier_B</bpmn:incoming>
      <bpmn:outgoing>Flow_B_Log</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_LogCase" name="Записва като support case за анализ">
      <bpmn:incoming>Flow_A_Log</bpmn:incoming>
      <bpmn:incoming>Flow_B_Log</bpmn:incoming>
      <bpmn:outgoing>Flow_Log_Want</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_WantFormal" name="Клиентът иска ли формална жалба?">
      <bpmn:incoming>Flow_Log_Want</bpmn:incoming>
      <bpmn:outgoing>Flow_Want_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Want_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_Register" name="Регистрира формална жалба (ref#, категория, приоритет)">
      <bpmn:incoming>Flow_Tier_CD</bpmn:incoming>
      <bpmn:incoming>Flow_Want_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Reg_Ack</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="SendTask_Ack" name="Потвърждение: in-app + email + push (ref#, срок, специалист)">
      <bpmn:incoming>Flow_Reg_Ack</bpmn:incoming>
      <bpmn:outgoing>Flow_Ack_Route</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Task_Route" name="Маршрутизиране към специалист по домейн">
      <bpmn:incoming>Flow_Ack_Route</bpmn:incoming>
      <bpmn:outgoing>Flow_Route_CoPilot</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_CoPilot" name="AI Ко-пилот сглобява контекст и предложено решение">
      <bpmn:incoming>Flow_Route_CoPilot</bpmn:incoming>
      <bpmn:outgoing>Flow_CoPilot_Inv</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Spec_Investigate" name="Специалистът разследва случая">
      <bpmn:incoming>Flow_CoPilot_Inv</bpmn:incoming>
      <bpmn:incoming>Flow_InfoBack_Inv</bpmn:incoming>
      <bpmn:outgoing>Flow_Inv_NeedInfo</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_NeedInfo" name="Нужна ли е допълнителна информация?">
      <bpmn:incoming>Flow_Inv_NeedInfo</bpmn:incoming>
      <bpmn:outgoing>Flow_NeedInfo_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_NeedInfo_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="SendTask_RequestInfo" name="Запитване към клиента: in-app + email + push">
      <bpmn:incoming>Flow_NeedInfo_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Req_Back</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_Spec_Decide" name="Специалистът одобрява предложение (Tier C) или формулира свое решение (Tier D)">
      <bpmn:incoming>Flow_NeedInfo_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Decide_Monetary</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_MonetaryAction" name="Монетарно/регулирано действие?">
      <bpmn:incoming>Flow_Decide_Monetary</bpmn:incoming>
      <bpmn:outgoing>Flow_Mon_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Mon_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ExecuteApproved" name="Изпълнение след изрично одобрение (аудит лог)">
      <bpmn:incoming>Flow_Mon_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Exec_Resp</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="SendTask_Response" name="Отговор: in-app + email + push">
      <bpmn:incoming>Flow_Mon_No</bpmn:incoming>
      <bpmn:incoming>Flow_Exec_Resp</bpmn:incoming>
      <bpmn:outgoing>Flow_Resp_ClientGw</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_ClientResp" name="Отговор на клиента">
      <bpmn:incoming>Flow_Resp_ClientGw</bpmn:incoming>
      <bpmn:outgoing>Flow_Client_Accept</bpmn:outgoing>
      <bpmn:outgoing>Flow_Client_Clarify</bpmn:outgoing>
      <bpmn:outgoing>Flow_Client_Escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Mgr_Review" name="Вътрешен преглед от ръководител">
      <bpmn:incoming>Flow_Client_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_Mgr_Outcome</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_MgrOutcome" name="Изход на прегледа">
      <bpmn:incoming>Flow_Mgr_Outcome</bpmn:incoming>
      <bpmn:outgoing>Flow_Mgr_Accept</bpmn:outgoing>
      <bpmn:outgoing>Flow_Mgr_External</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_External" name="Външна ескалация (БНБ / КЗП / ПКПС / FIN-NET)">
      <bpmn:incoming>Flow_Mgr_External</bpmn:incoming>
      <bpmn:outgoing>Flow_Ext_Survey</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Survey" name="Проучване за удовлетвореност">
      <bpmn:incoming>Flow_Client_Accept</bpmn:incoming>
      <bpmn:incoming>Flow_Mgr_Accept</bpmn:incoming>
      <bpmn:incoming>Flow_Ext_Survey</bpmn:incoming>
      <bpmn:incoming>Flow_Want_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Survey_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Survey" name="Край">
      <bpmn:incoming>Flow_Survey_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_Bot" sourceRef="StartEvent_Start" targetRef="Task_Bot_Collect"/>
    <bpmn:sequenceFlow id="Flow_Bot_NLP" sourceRef="Task_Bot_Collect" targetRef="Task_NLP"/>
    <bpmn:sequenceFlow id="Flow_NLP_Tier" sourceRef="Task_NLP" targetRef="Gateway_Tier"/>
    <bpmn:sequenceFlow id="Flow_Tier_A" name="Tier A" sourceRef="Gateway_Tier" targetRef="Task_TierA_Info"/>
    <bpmn:sequenceFlow id="Flow_Tier_B" name="Tier B" sourceRef="Gateway_Tier" targetRef="Task_TierB_Action"/>
    <bpmn:sequenceFlow id="Flow_Tier_CD" name="Tier C / D" sourceRef="Gateway_Tier" targetRef="Task_Register"/>
    <bpmn:sequenceFlow id="Flow_A_Log" sourceRef="Task_TierA_Info" targetRef="Task_LogCase"/>
    <bpmn:sequenceFlow id="Flow_B_Log" sourceRef="Task_TierB_Action" targetRef="Task_LogCase"/>
    <bpmn:sequenceFlow id="Flow_Log_Want" sourceRef="Task_LogCase" targetRef="Gateway_WantFormal"/>
    <bpmn:sequenceFlow id="Flow_Want_No" name="Не" sourceRef="Gateway_WantFormal" targetRef="Task_Survey"/>
    <bpmn:sequenceFlow id="Flow_Want_Yes" name="Да" sourceRef="Gateway_WantFormal" targetRef="Task_Register"/>

    <bpmn:sequenceFlow id="Flow_Reg_Ack" sourceRef="Task_Register" targetRef="SendTask_Ack"/>
    <bpmn:sequenceFlow id="Flow_Ack_Route" sourceRef="SendTask_Ack" targetRef="Task_Route"/>
    <bpmn:sequenceFlow id="Flow_Route_CoPilot" sourceRef="Task_Route" targetRef="Task_CoPilot"/>

    <bpmn:sequenceFlow id="Flow_CoPilot_Inv" sourceRef="Task_CoPilot" targetRef="Task_Spec_Investigate"/>
    <bpmn:sequenceFlow id="Flow_Inv_NeedInfo" sourceRef="Task_Spec_Investigate" targetRef="Gateway_NeedInfo"/>
    <bpmn:sequenceFlow id="Flow_NeedInfo_Yes" name="Да" sourceRef="Gateway_NeedInfo" targetRef="SendTask_RequestInfo"/>
    <bpmn:sequenceFlow id="Flow_NeedInfo_No" name="Не" sourceRef="Gateway_NeedInfo" targetRef="Task_Spec_Decide"/>
    <bpmn:sequenceFlow id="Flow_Req_Back" sourceRef="SendTask_RequestInfo" targetRef="Task_Spec_Investigate"/>
    <bpmn:sequenceFlow id="Flow_InfoBack_Inv" sourceRef="SendTask_RequestInfo" targetRef="Task_Spec_Investigate"/>
    <bpmn:sequenceFlow id="Flow_Decide_Monetary" sourceRef="Task_Spec_Decide" targetRef="Gateway_MonetaryAction"/>
    <bpmn:sequenceFlow id="Flow_Mon_Yes" name="Да" sourceRef="Gateway_MonetaryAction" targetRef="Task_ExecuteApproved"/>
    <bpmn:sequenceFlow id="Flow_Mon_No" name="Не" sourceRef="Gateway_MonetaryAction" targetRef="SendTask_Response"/>
    <bpmn:sequenceFlow id="Flow_Exec_Resp" sourceRef="Task_ExecuteApproved" targetRef="SendTask_Response"/>

    <bpmn:sequenceFlow id="Flow_Resp_ClientGw" sourceRef="SendTask_Response" targetRef="Gateway_ClientResp"/>
    <bpmn:sequenceFlow id="Flow_Client_Accept" name="Приема" sourceRef="Gateway_ClientResp" targetRef="Task_Survey"/>
    <bpmn:sequenceFlow id="Flow_Client_Clarify" name="Уточнение" sourceRef="Gateway_ClientResp" targetRef="Task_Spec_Investigate"/>
    <bpmn:sequenceFlow id="Flow_Client_Escalate" name="Ескалация" sourceRef="Gateway_ClientResp" targetRef="Task_Mgr_Review"/>
    <bpmn:sequenceFlow id="Flow_Mgr_Outcome" sourceRef="Task_Mgr_Review" targetRef="Gateway_MgrOutcome"/>
    <bpmn:sequenceFlow id="Flow_Mgr_Accept" name="Клиентът приема" sourceRef="Gateway_MgrOutcome" targetRef="Task_Survey"/>
    <bpmn:sequenceFlow id="Flow_Mgr_External" name="Външна ескалация" sourceRef="Gateway_MgrOutcome" targetRef="Task_External"/>
    <bpmn:sequenceFlow id="Flow_Ext_Survey" sourceRef="Task_External" targetRef="Task_Survey"/>
    <bpmn:sequenceFlow id="Flow_Survey_End" sourceRef="Task_Survey" targetRef="EndEvent_Survey"/>

    <bpmn:startEvent id="StartEvent_Start" name="Клиент открива проблем">
      <bpmn:outgoing>Flow_Start_Bot</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>

  <bpmn:process id="Process_Client" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Client" name="Има проблем">
      <bpmn:outgoing>Flow_Cl_Open</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Client_Open" name="Отваря Булбанк Мобайл &gt; Помощ &gt; Жалби">
      <bpmn:incoming>Flow_Cl_Open</bpmn:incoming>
      <bpmn:outgoing>Flow_Cl_Review</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Client_Review" name="Преглежда статус / отговор">
      <bpmn:incoming>Flow_Cl_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Cl_Info</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Client_ProvideInfo" name="Предоставя доп. информация при запитване">
      <bpmn:incoming>Flow_Cl_Info</bpmn:incoming>
      <bpmn:outgoing>Flow_Cl_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Client" name="Край">
      <bpmn:incoming>Flow_Cl_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Cl_Open" sourceRef="StartEvent_Client" targetRef="Task_Client_Open"/>
    <bpmn:sequenceFlow id="Flow_Cl_Review" sourceRef="Task_Client_Open" targetRef="Task_Client_Review"/>
    <bpmn:sequenceFlow id="Flow_Cl_Info" sourceRef="Task_Client_Review" targetRef="Task_Client_ProvideInfo"/>
    <bpmn:sequenceFlow id="Flow_Cl_End" sourceRef="Task_Client_ProvideInfo" targetRef="EndEvent_Client"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_Bank_di" bpmnElement="Participant_Bank" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2600" height="800"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Chatbot_di" bpmnElement="Lane_Chatbot" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="2570" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_CMS_di" bpmnElement="Lane_CMS" isHorizontal="true">
        <dc:Bounds x="190" y="280" width="2570" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Specialist_di" bpmnElement="Lane_Specialist" isHorizontal="true">
        <dc:Bounds x="190" y="480" width="2570" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="190" y="680" width="2570" height="200"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_Start_di" bpmnElement="StartEvent_Start">
        <dc:Bounds x="232" y="162" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="215" y="205" width="70" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Bot_Collect_di" bpmnElement="Task_Bot_Collect">
        <dc:Bounds x="320" y="140" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NLP_di" bpmnElement="Task_NLP">
        <dc:Bounds x="480" y="140" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Tier_di" bpmnElement="Gateway_Tier" isMarkerVisible="true">
        <dc:Bounds x="645" y="155" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="658" y="215" width="30" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TierA_Info_di" bpmnElement="Task_TierA_Info">
        <dc:Bounds x="740" y="90" width="120" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TierB_Action_di" bpmnElement="Task_TierB_Action">
        <dc:Bounds x="740" y="180" width="120" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LogCase_di" bpmnElement="Task_LogCase">
        <dc:Bounds x="900" y="140" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_WantFormal_di" bpmnElement="Gateway_WantFormal" isMarkerVisible="true">
        <dc:Bounds x="1065" y="155" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1045" y="120" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_Register_di" bpmnElement="Task_Register">
        <dc:Bounds x="1160" y="340" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_Ack_di" bpmnElement="SendTask_Ack">
        <dc:Bounds x="1320" y="340" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Route_di" bpmnElement="Task_Route">
        <dc:Bounds x="1500" y="340" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_CoPilot_di" bpmnElement="Task_CoPilot">
        <dc:Bounds x="1500" y="540" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Spec_Investigate_di" bpmnElement="Task_Spec_Investigate">
        <dc:Bounds x="1660" y="540" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_NeedInfo_di" bpmnElement="Gateway_NeedInfo" isMarkerVisible="true">
        <dc:Bounds x="1820" y="555" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1800" y="615" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_RequestInfo_di" bpmnElement="SendTask_RequestInfo">
        <dc:Bounds x="1770" y="340" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Spec_Decide_di" bpmnElement="Task_Spec_Decide">
        <dc:Bounds x="1920" y="540" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MonetaryAction_di" bpmnElement="Gateway_MonetaryAction" isMarkerVisible="true">
        <dc:Bounds x="2100" y="355" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2080" y="315" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExecuteApproved_di" bpmnElement="Task_ExecuteApproved">
        <dc:Bounds x="2190" y="260" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_Response_di" bpmnElement="SendTask_Response">
